<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aivpn.helper</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Library/PrivilegedHelperTools/aivpn-helper</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- NOTE: never point WorkingDirectory or Standard*Path at /var/run/aivpn.
         /var/run is cleared on every reboot, and launchd does NOT create missing
         parent directories for these paths (it only creates the log *file*, and
         WorkingDirectory is a plain chdir(2)). With the old /var/run/aivpn paths
         the spawn failed after any reboot — job "loaded" but the helper never ran,
         so the app perpetually showed "service unavailable". /var/log persists.
         The helper itself recreates /var/run/aivpn for its socket on each launch. -->
    <key>StandardErrorPath</key>
    <string>/var/log/aivpn-helper.log</string>

    <key>StandardOutPath</key>
    <string>/var/log/aivpn-helper.log</string>

    <key>UserName</key>
    <string>root</string>

    <key>GroupName</key>
    <string>wheel</string>

    <key>Umask</key>
    <integer>22</integer>

    <key>AssociatedBundleIdentifiers</key>
    <string>com.aivpn.client</string>
</dict>
</plist>
