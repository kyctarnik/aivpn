#!/bin/bash
# AIVPN PKG Pre-install Script
# Stops any existing helper daemon and cleans up orphaned processes

# Kill ALL aivpn-client processes (from old DMG runs, direct launches, etc.)
echo "Stopping all aivpn-client processes..."
pkill -9 -f "aivpn-client" 2>/dev/null || true
sleep 1

# Kill any running helper
echo "Stopping existing helper..."
pkill -9 -f "aivpn-helper" 2>/dev/null || true
sleep 1

# Unload LaunchDaemon (try both old and new API)
launchctl bootout system/com.aivpn.helper 2>/dev/null || true
launchctl unload /Library/LaunchDaemons/com.aivpn.helper.plist 2>/dev/null || true

# Clean up stale files
rm -f /var/run/aivpn/helper.sock /var/run/aivpn/client.pid /var/run/aivpn/client.log

echo "Pre-install cleanup complete"
exit 0
