#!/bin/bash
# AIVPN PKG Post-install Script
# Sets up directories, permissions, and starts the helper daemon

HELPER_PATH="/Library/PrivilegedHelperTools/aivpn-helper"
PLIST_PATH="/Library/LaunchDaemons/com.aivpn.helper.plist"
CLIENT_DIR="/Library/Application Support/AIVPN"
RUN_DIR="/var/run/aivpn"
LOG_FILE="/var/log/aivpn-postinstall.log"
HELPER_LOG="/var/log/aivpn-helper.log"

# Mirror everything this script prints (including launchctl errors we used to
# swallow with 2>/dev/null) to a persistent log file. The installer's own
# stdout/stderr capture (/var/log/install.log) can be hard to find; this
# gives a stable, dedicated place to check after a failed bootstrap.
exec > >(tee -a "$LOG_FILE") 2>&1
echo "=== postinstall run at $(date) ==="

# Remove quarantine attributes (macOS Sequoia provenance tracking)
echo "Removing quarantine attributes..."
xattr -cr "$HELPER_PATH" 2>/dev/null || true
xattr -cr "$PLIST_PATH" 2>/dev/null || true
xattr -cr "$CLIENT_DIR" 2>/dev/null || true

# Create runtime directories
mkdir -p "$RUN_DIR"
chmod 755 "$RUN_DIR"

mkdir -p "$CLIENT_DIR"
chmod 755 "$CLIENT_DIR"

# Set helper permissions
chmod 755 "$HELPER_PATH"

# Set plist permissions
chmod 644 "$PLIST_PATH"
chown root:wheel "$PLIST_PATH"

# Kill ALL orphaned aivpn-client processes (from old DMG runs etc.)
echo "Cleaning up old processes..."
pkill -9 -f "aivpn-client" 2>/dev/null || true
sleep 1

# Kill any running helper
pkill -9 -f "aivpn-helper" 2>/dev/null || true
sleep 1

# Remove stale socket and PID file
rm -f "$RUN_DIR/helper.sock" "$RUN_DIR/client.pid" "$RUN_DIR/client.log"

# Unload if already loaded (old style)
launchctl unload "$PLIST_PATH" 2>/dev/null || true
# Unload if already loaded (new style macOS 11+)
launchctl bootout system/com.aivpn.helper 2>/dev/null || true
sleep 1

# Load the LaunchDaemon using modern API (macOS 11+)
echo "Starting AIVPN helper daemon..."
BOOTSTRAP_ERR="$(launchctl bootstrap system "$PLIST_PATH" 2>&1 1>/dev/null)"
BOOTSTRAP_STATUS=$?
if [ "$BOOTSTRAP_STATUS" -eq 0 ]; then
    echo "✅ Loaded via launchctl bootstrap"
else
    echo "⚠️  launchctl bootstrap failed (exit $BOOTSTRAP_STATUS): ${BOOTSTRAP_ERR:-<no output>}"
    # Fallback for older macOS
    LOAD_ERR="$(launchctl load -w "$PLIST_PATH" 2>&1 1>/dev/null)"
    LOAD_STATUS=$?
    if [ "$LOAD_STATUS" -eq 0 ]; then
        echo "✅ Loaded via launchctl load"
    else
        echo "⚠️  launchctl load also failed (exit $LOAD_STATUS): ${LOAD_ERR:-<no output>}"
        echo "⚠️  launchctl failed, starting helper directly"
    fi
fi

# Wait for daemon to start
sleep 2

# Verify the daemon is running
if launchctl list com.aivpn.helper &>/dev/null; then
    echo "✅ AIVPN helper daemon registered with launchctl"
elif pgrep -x "aivpn-helper" &>/dev/null; then
    echo "✅ AIVPN helper daemon is running"
else
    echo "⚠️  Helper daemon may not have started"
    echo "--- launchctl print system/com.aivpn.helper (diagnostic) ---"
    launchctl print system/com.aivpn.helper 2>&1 || echo "(job not known to launchd at all)"
    echo "--- end diagnostic ---"
    # Try starting directly as fallback. Fully detach stdio from this script
    # (which is about to exit) so the child doesn't block/die on a closed
    # pipe, and disown it so it isn't tied to this script's job table.
    # Log to /var/log (persists across reboots) — same path as the LaunchDaemon
    # plist's StandardOutPath/StandardErrorPath, so all helper output is in one place.
    nohup "$HELPER_PATH" </dev/null >>"$HELPER_LOG" 2>&1 &
    disown
    sleep 1
    if pgrep -x "aivpn-helper" &>/dev/null; then
        echo "✅ Helper started directly (fallback, not launchd-managed)"
    else
        echo "❌ Helper failed to start even via direct fallback — see $HELPER_LOG and $LOG_FILE"
    fi
fi

echo "Post-install complete"
exit 0
