DATABASE_URL=file:./data/aivpn-web.db
# DATABASE_URL=postgres://user:pass@localhost:5432/aivpn_web
JWT_SECRET=change-me-to-a-long-random-string
# AES-256-GCM key for encrypting TOTP secrets at rest.
# Required when using TOTP 2FA. Generate: openssl rand -base64 32
TOTP_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32
ORIGIN=https://vpn.example.com
PORT=8080
UNIX_SOCK=/run/aivpn/api.sock
# AIVPN_WEB_ADMIN_PASSWORD=initial-admin-password

# Trust X-Forwarded-For / X-Real-IP headers for client IP (rate limiting,
# audit log, session records). Set to true ONLY when the panel runs behind a
# trusted reverse proxy (e.g. nginx) that OVERWRITES these headers. If the
# panel is directly reachable, leave false — otherwise any client can spoof
# its IP to bypass per-IP rate limits and forge audit-log entries.
AIVPN_WEB_TRUST_PROXY=false

# ── OIDC / SSO (optional) ────────────────────────────────────────────────────
# OIDC_MODE=disabled          # disabled | enabled | exclusive
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=         # optional for public PKCE clients
# OIDC_ROLE_CLAIM=role        # ID token claim to read role from
# OIDC_ADMIN_VALUE=admin      # claim value that grants admin role
