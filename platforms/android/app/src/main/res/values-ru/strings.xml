    <string name="bg_health_summary_at_risk">Под угрозой — Android может незаметно убить VPN в фоне</string>
    <string name="bg_health_fix">Исправить</string>
    <string name="bg_health_open">Открыть</string>
    <string name="bg_health_check_notifications">Уведомления</string>
