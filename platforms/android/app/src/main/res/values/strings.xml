    <!-- Menu item descriptions -->
    <string name="desc_adaptive_mode">Controls traffic mimicry (HTTPS/QUIC/Zoom) and keepalive frequency. Higher level = better DPI evasion, higher bandwidth overhead</string>
    <string name="desc_adaptive_off">Encryption only. No traffic mimicry.</string>
    <string name="desc_adaptive_light">Basic mimicry. Keepalive every 15 s.</string>
    <string name="desc_adaptive_aggressive">HTTPS/QUIC mimicry. Keepalive every 8 s.</string>
    <string name="desc_adaptive_satellite">Optimized for high latency (>300 ms). Maximum mimicry.</string>
    <string name="desc_diagnostics">Measures latency (p50/p95) and packet loss to server. Requires active connection.</string>
    <string name="desc_recording">Records network profile of this session. Used to create a personal mask — a traffic fingerprint that trains the DPI evasion engine.</string>
    <string name="desc_export_logs">Collects technical logs for troubleshooting connection errors.</string>
    <string name="desc_kill_switch">Opens Android VPN settings. Enable "Always-on VPN" + "Block connections without VPN" to prevent traffic leaks on disconnect.</string>
    <string name="desc_bootstrap_discovery">Advanced: fetch fresh signed mask material for a known server via CDN/GitHub/Telegram, instead of a new full connection key.</string>
    <string name="split_tunnel_desc">Select which apps route through VPN. By default all traffic is protected.</string>

