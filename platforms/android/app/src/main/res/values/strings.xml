    <!-- Background reliability & permissions health check -->
    <string name="bg_health_title">Background health</string>
    <string name="btn_bg_health">Background Health</string>
    <string name="bg_health_intro">These settings decide whether Android may silently kill the VPN in the background. Fix every amber item for a reliable always-on tunnel.</string>
    <string name="bg_health_summary_protected">Protected — background settings look good</string>
    <string name="bg_health_summary_mostly">Almost protected — also enable “Block connections without VPN” for a real kill switch</string>
    <string name="bg_health_summary_at_risk">At risk — Android may silently kill the VPN in the background</string>
    <string name="bg_health_fix">Fix</string>
    <string name="bg_health_open">Open</string>
    <string name="bg_health_check_notifications">Notifications</string>
    <string name="bg_health_notifications_ok">Enabled — you will see “VPN stopped” security alerts</string>
    <string name="bg_health_notifications_bad">Disabled — disconnect and security alerts will NOT be shown</string>
    <string name="bg_health_check_battery">Battery optimization exemption</string>
    <string name="bg_health_battery_ok">Exempt — Doze will not kill the VPN service</string>
    <string name="bg_health_battery_bad">Not exempt — the most common cause of the VPN dying in the background. Tap Fix and choose Allow.</string>
    <string name="bg_health_check_bg_restriction">Background activity</string>
    <string name="bg_health_bg_ok">Not restricted</string>
    <string name="bg_health_bg_bad">Restricted — Android will stop the VPN soon after you leave the app. Remove the restriction: App info → Battery.</string>
    <string name="bg_health_check_always_on">Always-on VPN</string>
    <string name="bg_health_always_on_ok">Enabled — the system restarts the VPN automatically</string>
    <string name="bg_health_always_on_off">Off — enable Always-on for AIVPN in system VPN settings (gear next to AIVPN)</string>
    <string name="bg_health_check_lockdown">Block connections without VPN</string>
    <string name="bg_health_lockdown_ok">Enabled — real kill switch: nothing leaks even if the VPN dies</string>
    <string name="bg_health_lockdown_off">Off — if the VPN dies, traffic silently reverts to your real IP. This OS toggle is the only real kill switch.</string>
    <string name="bg_health_unknown_service_off">Cannot verify while the VPN service is not running — check in system VPN settings</string>
    <string name="bg_health_check_oem">Autostart (%s)</string>
    <string name="bg_health_oem_desc">This manufacturer’s firmware may additionally require enabling Autostart / removing AIVPN from “sleeping apps”. Best effort — the screen may not exist on your device.</string>
    <string name="bg_health_oem_generic">Some devices also require enabling “Autostart” for AIVPN in the manufacturer’s battery/security app.</string>
    <string name="bg_health_hint_ok">Background: protected</string>
    <string name="bg_health_hint_risk">Background: at risk — tap to fix</string>
