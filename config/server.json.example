{
  "listen_addr": "0.0.0.0:443",
  "tun_name": "aivpn0",
  "network_config": {
    "server_vpn_ip": "10.0.0.1",
    "prefix_len": 24,
    "mtu": 1346
  },
  "mask_dir": "/var/lib/aivpn/masks",
  "max_sessions": 500,
  "session_timeout_secs": 0,
  "idle_timeout_secs": 300,
  "default_mask": "webrtc_zoom_v3"
}
